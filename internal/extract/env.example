# Claude Code Dashboard Configuration
# Copy to .env and adjust to your setup:  cp .env.example .env

# ── Current Plan ─────────────────────────────────────────
# Plan name: "Pro" or "Max"
PLAN_NAME=Max
# Credit tier: "pro", "5x", or "20x" (inferred from PLAN_NAME if empty)
PLAN_TIER=5x
# ISO date when this plan started
PLAN_START=2025-02-01
# ISO date when plan ended (leave empty for active plan)
PLAN_END=
# Monthly cost in USD
PLAN_COST_USD=93.00
# Day of month billing occurs (1-31)
PLAN_BILLING_DAY=1

# ── Previous Plans (optional, numbered) ──────────────────
# Add historical plans with _2, _3, etc. suffixes
# PLAN_2_NAME=Pro
# PLAN_2_TIER=pro
# PLAN_2_START=2025-01-01
# PLAN_2_END=2025-01-31
# PLAN_2_COST_USD=20.00
# PLAN_2_BILLING_DAY=
